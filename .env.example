# LLM backend selection (priority order):
#   1. HF_ENDPOINT_URL  → Hugging Face inference endpoint
#   2. USE_LLAMACPP     → llama-cpp-python local GGUF model
#   3. (default)        → Hugging Face transformers local model

# HF_ENDPOINT_URL=https://your-endpoint.hf.space
# USE_LLAMACPP=true
# LOCAL_MODEL_PATH=./models/model.gguf
# HF_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# Mt Washington Observatory MCP server (optional overrides)
# MCP_WEATHER_URL=https://mt-washington-weather.fastmcp.app/mcp
# MCP_WEATHER_API_KEY=your_fastmcp_bearer_token
DEEPEVAL_TELEMETRY_OPT_OUT=1